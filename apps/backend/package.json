{
  "name": "backend",
  "module": "src/index.ts",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "build": "prisma generate && tsdown",
    "postinstall": "prisma generate",
    "start": "bun --env-file=.env.production dist/index.mjs",
    "dev:turso": "bun --env-file=.env.production src/server.ts",
    "prod:sql": "bunx prisma migrate diff --from-empty --to-schema prisma/schema.prisma --script > baseline.sql",
    "prod:check-env": "bun --env-file=.env.production -e \"console.log(process.env.DATABASE_URL)\"",
    "prod:migrate": "bun --env-file=.env.production prisma/migrate.ts",
    "prod:seed": "bun --env-file=.env.production prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-ssm": "^3.1053.0",
    "@elysiajs/cookie": "^0.8.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/swagger": "^1.3.1",
    "@googleapis/classroom": "^11.1.0",
    "@libsql/client": "0.8.1",
    "@prisma/adapter-libsql": "^7.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.3",
    "elysia": "^1.4.28",
    "googleapis": "^171.4.0",
    "oslo": "^1.2.1",
    "pg": "^8.21.0",
    "shared": "workspace:*"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1053.0",
    "@aws-sdk/client-iam": "^3.1053.0",
    "@aws-sdk/client-lambda": "^3.1053.0",
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/client-sts": "^3.1053.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "^1.3.10",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "mime-types": "^3.0.2",
    "prisma": "^7.5.0",
    "tsdown": "^0.21.7"
  },
  "optionalDependencies": {
    "@libsql/linux-x64-gnu": "^0.5.29"
  }
}